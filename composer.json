{
  "name": "jord-jd/baby-tracker-data-parser",
  "description": "PHP parser for data exported from the Baby Tracker Android app by Amila",
  "type": "library",
  "license": "LGPL-3.0-only",
  "authors": [
    {
      "name": "Jordan Hall",
      "email": "jordan@hall05.co.uk"
    }
  ],
  "require": {
    "php": ">=7.1",
    "ext-zip": "*",
    "jord-jd/uxdm": "^6.2",
    "nesbot/carbon": "^1.26.3 || ^2.0 || ^3.0",
    "illuminate/support": "^5.1 || ^6.0 || ^7.0 || ^8.0 || ^9.0 || ^10.0 || ^11.0 || ^12.0 || ^13.0"
  },
  "autoload": {
    "psr-4": {
      "JordJD\\BabyTrackerDataParser\\": "src/"
    }
  },
  "replace": {
    "divineomega/baby-tracker-data-parser": "self.version"
  },
  "autoload-dev": {
    "psr-4": {
      "JordJD\\BabyTrackerDataParser\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^7.5 || ^9.6 || ^12.0"
  },
  "extra": {
    "branch-alias": {
      "dev-master": "3.1-dev"
    }
  }
}
